# ---- Database (PostgreSQL) ----
# Use a local Postgres or a hosted provider (Neon, Supabase, Railway).
DATABASE_URL="postgresql://user:password@localhost:5432/cryptopulse?schema=public"

# ---- Clerk authentication ----
# Get keys at https://dashboard.clerk.com (the app runs without these in dev).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ---- Anthropic (Claude) for AI analysis & chart scanner ----
# Get a key at https://console.anthropic.com (falls back to rule-based math if absent).
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# ---- Optional overrides ----
# BINANCE_REST_BASE="https://data-api.binance.vision"
# NEXT_PUBLIC_BINANCE_WS_BASE="wss://data-stream.binance.vision"

# ---- News (optional) ----
# CryptoPanic free API token for live news; otherwise curated fallback is used.
CRYPTOPANIC_TOKEN=""
